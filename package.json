{
  "name": "server-fetch",
  "version": "1.0.10",
  "description": "SSRF-safe fetch() for server-side use — validates IPs, enforces scheme/port, eliminates DNS rebinding via undici connect.lookup",
  "keywords": [
    "dns-rebinding",
    "fetch",
    "security",
    "server-side",
    "ssrf",
    "undici"
  ],
  "homepage": "https://github.com/GalvinGao/server-fetch#readme",
  "bugs": "https://github.com/GalvinGao/server-fetch/issues",
  "license": "MIT",
  "author": "GalvinGao",
  "repository": {
    "type": "git",
    "url": "https://github.com/GalvinGao/server-fetch.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@j178/prek": "^0.3.11",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "tsdown": "^0.21.10",
    "typescript": "6.0.3",
    "undici": "^8.2.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "undici": "^8.2.0"
  },
  "engines": {
    "node": ">=20.20.2"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
